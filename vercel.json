{
  "version": 2,
  "buildCommand": "next build",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "CDN-Cache-Control", "value": "no-cache" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
